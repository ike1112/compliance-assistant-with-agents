#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel | tr -d '\r')"

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/run-quality-gate.ps1" -Hook pre-commit
fi

exec powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/run-quality-gate.ps1" -Hook pre-commit
