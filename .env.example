MODEL=bedrock/us.amazon.nova-pro-v1:0
AWS_REGION_NAME=us-east-1
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
MAX_TOKENS=4000
TEMPERATURE=0.0
# With the infra stack deployed, the agent ids are read from SSM at
# these paths and the two AGENT_ID*/ values below are ignored. They
# stay as a fallback for deliberate local runs without the stack. Do
# not copy old deployed ids into this file; the hardened path expects
# SSM to be the source of truth.
AGENT_ID_SSM_PATH=/compliance-assistant/agent-id
AGENT_ALIAS_ID_SSM_PATH=/compliance-assistant/agent-alias-id
AGENT_ID=replace-with-your-amazon-bedrock-agent-id
AGENT_ALIAS_ID=replace-with-your-amazon-bedrock-agent-alias-id
# Deliberately use the AGENT_ID*/ env values above instead of SSM, for a
# local run without the stack. Truthy (1/true/yes/on) opts in. When
# unset, a reachable-but-misconfigured SSM fails closed rather than
# silently falling back to these.
USE_ENV_AGENT_IDS=
TOPIC=Latest PCI DSS requirements for Banking Organizations
# Step-by-step agent log. Off unless set truthy (1/true/yes/on).
CREW_VERBOSE=
# Opt-in live capture of crew tracing spans (re-records the offline
# fixture from a real run). Off unless truthy (1/true/yes/on); the
# gate always runs offline against the committed fixture.
TRACING_LIVE=
# Opt-in emission of the ComplianceAssistant/Quality SLO metrics
# (Faithfulness, CitationCorrectness) as CloudWatch EMF from the eval
# report path. Off by default so the deterministic offline gate never
# emits and scoring is unchanged; set truthy on a live/refresh eval.
EVALS_EMIT_METRICS=
# The repo is still "verified in code and tests, not yet proven in
# production" until the operator completes the live launch protocol.
