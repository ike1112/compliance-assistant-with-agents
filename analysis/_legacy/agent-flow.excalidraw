      "locked": false,
      "text": "Solid arrows = work handed from one worker to the next.   Dashed arrows = a worker thinking with the AI brain.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solid arrows = work handed from one worker to the next.   Dashed arrows = a worker thinking with the AI brain.",
      "lineHeight": 1.25,
      "baseline": 12,
      "version": 2,
      "index": "aa",
      "autoResize": true
    },
    {
      "id": "k0yduzdueo14qpc7",
      "type": "text",
      "x": 50,
      "y": 1052,
      "width": 1000,
      "height": 15,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 205734526,
      "versionNonce": 1698633975,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778867467170,
      "link": null,
      "locked": false,
      "text": "The big idea: only the Researcher can reach the document library, and only through the Lookup Tool. The other two just think about what the Researcher found.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The big idea: only the Researcher can reach the document library, and only through the Lookup Tool. The other two just think about what the Researcher found.",
      "lineHeight": 1.25,
      "baseline": 12,
      "version": 2,
      "index": "ab",
      "autoResize": true
    },
