      "versionNonce": 714429751,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778867467170,
      "link": null,
      "locked": false,
      "text": "THE RESEARCHER\n\nLooks up the latest rules on the\nsubject and picks out the points\nthat matter most.\nThe only worker allowed to look\nthings up in the document library.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "mrvftva0hipgad35",
      "originalText": "THE RESEARCHER\n\nLooks up the latest rules on the\nsubject and picks out the points\nthat matter most.\nThe only worker allowed to look\nthings up in the document library.",
      "lineHeight": 1.25,
      "baseline": 14,
      "version": 2,
      "index": "a9",
      "autoResize": true
    },
    {
      "id": "sx7ifxi2v7icb4wt",
      "type": "text",
      "x": 107,
      "y": 477.5,
      "width": 436,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 136015288,
      "versionNonce": 1946090937,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778867467170,
      "link": null,
      "locked": false,
      "text": "THE REPORT WRITER\n\nTakes the researcher's key points\nand turns them into a full written\nreport. Works only from what it\nwas handed - looks nothing up.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "9m26mi0yhz0nartb",
      "originalText": "THE REPORT WRITER\n\nTakes the researcher's key points\nand turns them into a full written\nreport. Works only from what it\nwas handed - looks nothing up.",
      "lineHeight": 1.25,
      "baseline": 14,
      "version": 2,
      "index": "aA",
      "autoResize": true
    },
    {
      "id": "e4etuiee28xcivwf",
      "type": "text",
      "x": 107,
      "y": 722.5,
      "width": 436,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 835669865,
      "versionNonce": 230921815,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778867467170,
      "link": null,
      "locked": false,
      "text": "THE SOLUTION DESIGNER\n\nReads the report and works out how\nto actually build it on AWS, with\nconcrete recommendations.\nProduces the finished document.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "zgcjn2qavsyeefnp",
      "originalText": "THE SOLUTION DESIGNER\n\nReads the report and works out how\nto actually build it on AWS, with\nconcrete recommendations.\nProduces the finished document.",
      "lineHeight": 1.25,
      "baseline": 14,
      "version": 2,
      "index": "aB",
      "autoResize": true
    },
