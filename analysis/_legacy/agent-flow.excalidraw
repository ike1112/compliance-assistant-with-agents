      "text": "THE LIBRARIAN AI\nSearches the documents and\nchecks answers are safe.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "ounii5wcerkh24rn",
      "originalText": "THE LIBRARIAN AI\nSearches the documents and\nchecks answers are safe.",
      "lineHeight": 1.25,
