      "updated": 1778867467170,
      "link": null,
      "locked": false,
      "text": "The subject to analyze\n(e.g. PCI DSS for banks)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "gzgsyebannd4yz0e",
      "originalText": "The subject to analyze\n(e.g. PCI DSS for banks)",
      "lineHeight": 1.25,
      "baseline": 13,
      "version": 2,
      "index": "a8",
      "autoResize": true
    },
    {
      "id": "eio49ernnber02pd",
      "type": "text",
      "x": 107,
      "y": 223.75,
      "width": 436,
      "height": 122.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
